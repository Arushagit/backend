# ======================
# Django Core
# ======================
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production-min-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ======================
# MongoDB
# ======================
MONGODB_URI=mongodb://localhost:27017/crm_db
# For MongoDB Atlas (production):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/crm_db

# ======================
# Admin Credentials
# ======================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=AdminPass@123
ADMIN_EMAIL=admin@yoursite.com

# ======================
# JWT Settings
# ======================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ======================
# Gmail SMTP Email
# ======================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your.gmail@gmail.com
# Generate App Password at: https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
DEFAULT_FROM_EMAIL=ExpertiseCo <your.gmail@gmail.com>
NOTIFICATION_EMAIL=admin@yoursite.com

# ======================
# CORS (Frontend URLs)
# ======================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
